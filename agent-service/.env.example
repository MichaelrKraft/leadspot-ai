# LeadSpot Agent Service - Environment Variables

# Server
AGENT_SERVICE_PORT=3008
NODE_ENV=development

# AI
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# Backend API
LEADSPOT_API_URL=http://localhost:8000

# Email delivery (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
FROM_EMAIL=outreach@mail.yourdomain.com
PHYSICAL_ADDRESS=123 Your St, City, ST 00000

# Unsubscribe token signing (generate with: openssl rand -hex 32)
UNSUBSCRIBE_SECRET=generate-with-openssl-rand-hex-32

# App URL (used for unsubscribe links in emails)
APP_URL=https://yourdomain.com

# Error tracking (optional)
SENTRY_DSN=

# Timezone
DEFAULT_TIMEZONE=America/Los_Angeles
