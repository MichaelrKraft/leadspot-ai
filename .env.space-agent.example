# ===== SPACE AGENT INTEGRATION =====
# Backend
SPACE_AGENT_URL=http://localhost:3009
SPACE_AGENT_API_KEY=<openssl rand -hex 32>
SPACE_AGENT_ADMIN_KEY=<openssl rand -hex 32>
SPACE_AGENT_API_KEY_PREVIOUS=

# Frontend
NEXT_PUBLIC_SPACE_AGENT_ENABLED=false
NEXT_PUBLIC_SPACE_AGENT_URL=/workspace

# Space Agent service (consumed by space-agent docker container)
PORT=3009
NODE_ENV=production
LEADSPOT_API_URL=http://backend:8000
LEADSPOT_SPACE_API_KEY=<same-as-SPACE_AGENT_API_KEY>
SPACE_AGENT_DATA_DIR=/data
