# =============================================================================
# LeadSpot.ai Backend Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# SECURITY WARNING: Never commit .env with real secrets to git!
# =============================================================================

# Environment: development | staging | production
# In production the app will fail fast if required secrets are missing
ENVIRONMENT=development

# Application Settings
APP_NAME=LeadSpot.ai
DEBUG=False
API_PREFIX=/api

# CORS Origins - comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3006,http://localhost:3000

# =============================================================================
# DATABASE
# =============================================================================

# Option 1: SQLite (local dev, no setup required — auto-used if blank in dev)
DATABASE_URL=sqlite+aiosqlite:///./leadspot.db
# Option 2: PostgreSQL (recommended for production)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/leadspot

# Graph Database (Neo4j) — optional, for knowledge graph features
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Vector Database (Pinecone) — optional, sync worker disabled if blank
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX=leadspot-embeddings

# Cache (Redis) — optional
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# AI APIs
# =============================================================================

# Anthropic Claude — required for chat and AI features
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — required for embeddings and sync worker
OPENAI_API_KEY=sk-...

# Embedding / Synthesis settings (defaults are fine for dev)
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
SYNTHESIS_MODEL=claude-sonnet-4-6
MAX_SOURCES=10
QUERY_TIMEOUT_SECONDS=30
MAX_QUERY_LENGTH=500

# =============================================================================
# AUTHENTICATION  (CRITICAL)
# =============================================================================

# JWT Secret — REQUIRED (min 32 chars)
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# In development a random secret is auto-generated if blank (no session persistence)
# In production the app will FAIL TO START without this
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7

# URLs for OAuth redirects
API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3006

# Encryption key for stored OAuth tokens — required in production
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# =============================================================================
# OAUTH PROVIDERS  (all optional)
# =============================================================================

# Google — https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft — https://portal.azure.com/
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Slack — https://api.slack.com/apps
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Salesforce — https://developer.salesforce.com/
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_INSTANCE_URL=https://login.salesforce.com

# =============================================================================
# MAUTIC CRM  (optional — enables 14 marketing automation tools)
# =============================================================================

MAUTIC_URL=https://your-mautic-instance.com
MAUTIC_CLIENT_ID=
MAUTIC_CLIENT_SECRET=
LEADSPOT_URL=http://localhost:3006

# =============================================================================
# FILE STORAGE
# =============================================================================

UPLOAD_DIR=./uploads

# =============================================================================
# ERROR TRACKING  (optional)
# =============================================================================

# Sentry DSN — get yours at https://sentry.io/
SENTRY_DSN=
